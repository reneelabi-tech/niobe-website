---
page_id: about
permalink: /about.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ about.meta_title }}</title>
  <meta name="description" content="{{ about.meta_desc }}" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

  {% include "nav.njk" %}

  <main>

    <div class="page-hero">
      <div class="page-hero__inner">
        <span class="eyebrow">{{ about.hero.eyebrow }}</span>
        <h1 class="t-display t-lg page-hero__title">
          {{ about.hero.title }}<br><em>{{ about.hero.title_em }}</em>
        </h1>
        <p class="page-hero__desc">{{ about.hero.desc }}</p>
      </div>
    </div>


    <section class="section" aria-labelledby="story-heading">
      <div class="wrap">
        <div class="about-split">
          <div class="fade-up">
            <span class="eyebrow">{{ about.story.eyebrow }}</span>
            <h2 id="story-heading" class="t-display t-md about-split__title" style="margin-top: 0.5rem;">
              {{ about.story.title }}<br>{{ about.story.title_2 }}<br><em>{{ about.story.title_em }}</em>
            </h2>
          </div>
          <div class="about-split__body fade-up d2">
            {% for para in about.story.paragraphs %}
            <p>{{ para }}</p>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>


    <section class="section section--sage" aria-labelledby="credentials-heading">
      <div class="wrap">
        <div class="sec-head--center" style="margin-bottom: clamp(2.5rem, 5vw, 4rem);">
          <span class="eyebrow fade-in" style="color: rgba(33,26,18,0.5);">{{ about.credentials.eyebrow }}</span>
          <h2 id="credentials-heading" class="t-display t-md fade-up d1" style="margin-top: 0.5rem;">
            {{ about.credentials.heading }}
          </h2>
        </div>
        <div class="credentials-grid fade-up d2">
          {% for item in about.credentials.items %}
          <div class="cred-card">
            <p class="cred-card__num">{{ item.number }}</p>
            <p class="cred-card__label">{{ item.label }}</p>
            <p class="cred-card__body">{{ item.body }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>


    <section class="section" aria-labelledby="approach-heading">
      <div class="wrap">
        <div style="max-width: 580px; margin-bottom: clamp(3rem, 6vw, 5rem);" class="fade-up">
          <span class="eyebrow">{{ about.approach.eyebrow }}</span>
          <h2 id="approach-heading" class="t-display t-md" style="margin-top: 0.5rem;">
            {{ about.approach.heading }}<br><em>{{ about.approach.heading_em }}</em>
          </h2>
        </div>
        <div class="brand-values fade-up d2">
          {% for value in about.approach.values %}
          <div class="bv-item">
            <div class="rule"></div>
            <h3 class="bv-item__title">{{ value.title }}</h3>
            <p class="bv-item__body">{{ value.body }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>


    <section class="section section--sage" aria-labelledby="visit-heading">
      <div class="wrap">
        <h2 id="visit-heading" class="t-display t-sm fade-up" style="margin-bottom: clamp(2rem, 4vw, 3.5rem);">
          {{ about.before_visit.heading }}
        </h2>
        <div class="grid-2 fade-up d1">
          {% for item in about.before_visit.items %}
          <div>
            <div class="rule" style="margin-bottom: 1.25rem;"></div>
            <h3 class="t-display t-xs" style="margin-bottom: 0.75rem;">{{ item.title }}</h3>
            <p class="body-sm" style="opacity: 0.68;">{{ item.body }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>


    <section class="section--onyx">
      <div class="cta-block">
        <span class="eyebrow fade-in" style="color: rgba(255,255,245,0.4);">{{ about.cta.eyebrow }}</span>
        <h2 class="t-display t-lg fade-up d1" style="color: var(--ivory); max-width: 14ch;">
          {{ about.cta.title }}<br><em>{{ about.cta.title_em }}</em>
        </h2>
        <div class="cta-block__actions fade-up d2">
          <a href="/contact.html#book"      class="btn btn-outline-light">Book a Treatment</a>
          <a href="/contact.html#locations" class="btn btn-outline-light">Our Locations</a>
        </div>
      </div>
    </section>

  </main>

  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
</body>
</html>
