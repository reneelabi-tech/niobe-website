---
page_id: contact
permalink: /contact.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ contact.meta_title }}</title>
  <meta name="description" content="{{ contact.meta_desc }}" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>

  {% include "nav.njk" %}

  <main>

    <div class="page-hero">
      <div class="page-hero__inner">
        <span class="eyebrow">{{ contact.hero.eyebrow }}</span>
        <h1 class="t-display t-lg page-hero__title">
          {{ contact.hero.title }}<br><em>{{ contact.hero.title_em }}</em>
        </h1>
        <p class="page-hero__desc">{{ contact.hero.desc }}</p>
      </div>
    </div>


    <section class="section" id="book">
      <div class="wrap">
        <div class="contact-layout">

          <div class="fade-up">
            <span class="eyebrow" style="margin-bottom: 1.5rem; display: block;">Contact us directly</span>

            <div class="contact-block">
              <span class="eyebrow contact-block__label">{{ contact.contact.whatsapp_label }}</span>
              <p class="contact-block__val">
                <a href="{{ contact.contact.whatsapp_url }}">{{ contact.contact.whatsapp_number }}</a>
              </p>
            </div>

            <div class="contact-block">
              <span class="eyebrow contact-block__label">{{ contact.contact.locations_label }}</span>
              <p class="contact-block__val" style="font-size: 0.9375rem; font-family: var(--font-sans); font-weight: 300; line-height: 1.8;">
                {% for loc in contact.contact.locations %}
                {{ loc }}<br>
                {% endfor %}
              </p>
            </div>

            <div class="contact-block">
              <span class="eyebrow contact-block__label">{{ contact.contact.payment_label }}</span>
              <p class="contact-block__val" style="font-size: 0.9375rem; font-family: var(--font-sans); font-weight: 300; line-height: 1.8;">
                Cash · Bank transfer · Visa<br>
                Mobile money (MTN &amp; Telecel)
              </p>
            </div>

            <div class="deposit-note" style="margin-top: 2rem;">
              {{ contact.contact.deposit_note }}
            </div>
          </div>

          <div class="fade-up d2">
            <h2 class="t-display t-sm" style="margin-bottom: 2rem;">{{ contact.form.heading }}</h2>

            <form class="form" novalidate>
              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="c-fname">First name</label>
                  <input class="form-input" type="text" id="c-fname" name="first_name" placeholder="First name" autocomplete="given-name" required />
                </div>
                <div class="form-field">
                  <label class="form-label" for="c-lname">Last name</label>
                  <input class="form-input" type="text" id="c-lname" name="last_name" placeholder="Last name" autocomplete="family-name" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="c-phone">Phone / WhatsApp</label>
                  <input class="form-input" type="tel" id="c-phone" name="phone" placeholder="+233" autocomplete="tel" required />
                </div>
                <div class="form-field">
                  <label class="form-label" for="c-email">Email <span style="opacity: 0.45;">(optional)</span></label>
                  <input class="form-input" type="email" id="c-email" name="email" placeholder="your@email.com" autocomplete="email" />
                </div>
              </div>

              <div class="form-field">
                <label class="form-label" for="c-location">Preferred location</label>
                <select class="form-select" id="c-location" name="location">
                  <option value="" disabled selected>Select a location</option>
                  {% for loc in contact.contact.locations %}
                  <option>{{ loc }}</option>
                  {% endfor %}
                  <option>No preference</option>
                </select>
              </div>

              <div class="form-field">
                <label class="form-label" for="c-treatment">Treatment or package</label>
                <select class="form-select" id="c-treatment" name="treatment">
                  <option value="" disabled selected>Select a treatment or package</option>
                  <optgroup label="Facials">
                    <option>Elemis BIOTEC Facials</option>
                    <option>Elemis BIOTEC Line Eraser</option>
                    <option>Elemis BIOTEC Triple-Tec Anti-Wrinkle</option>
                    <option>Million Dollar Super Facial</option>
                  </optgroup>
                  <optgroup label="Body Massage">
                    <option>Elemis Deeper Than Deep Hot Stone Massage</option>
                    <option>Elemis Freestyle Deep Tissue Massage</option>
                    <option>Elemis Rose Restore Massage (Swedish)</option>
                    <option>Elemis Hot Mineral Body Boost Massage</option>
                    <option>Elemis Peaceful Pregnancy Massage</option>
                    <option>Head, Back and Neck Massage</option>
                    <option>Reflexology</option>
                    <option>Foot Massage</option>
                    <option>Indian Head Massage</option>
                  </optgroup>
                  <optgroup label="Body Wraps &amp; Scrubs">
                    <option>Intensely Cleansing Salt Scrub (Lime &amp; Ginger)</option>
                    <option>Exotic Frangipani Body Nourish Wrap</option>
                    <option>Exotic Coconut Rub and Milk Ritual Wrap</option>
                    <option>Cellutox Aroma Spa Ocean Wrap</option>
                    <option>Universal Contour Wrap</option>
                  </optgroup>
                  <optgroup label="Spa Packages">
                    <option>Elemis Couture Touch (60 min)</option>
                    <option>Elemis Couture Technology BIOTEC (120 min)</option>
                    <option>Elemis Bliss Package</option>
                    <option>Elemis Beautiful Bride Package</option>
                    <option>Elemis Peaceful Pregnancy Package</option>
                    <option>Elemis Love Package (Solo)</option>
                    <option>Elemis Love Package (For Two)</option>
                    <option>Time Out Package</option>
                    <option>Indulge Package</option>
                    <option>Relax Package</option>
                    <option>Spa Alone Treat Package</option>
                    <option>Spa Together</option>
                    <option>The Ultimate Spa Escape (3.5 hrs)</option>
                    <option>Serenity Package (5 hrs)</option>
                    <option>Niobe Spa Escape Journey (5+ hrs)</option>
                    <option>Hammam Ritual Package</option>
                    <option>Hammam Turkish Bath Ceremony</option>
                    <option>Hammam Thousand and One Night</option>
                  </optgroup>
                  <optgroup label="Thermal">
                    <option>Steam</option>
                    <option>Sauna</option>
                    <option>Jacuzzi</option>
                  </optgroup>
                  <option value="other">I'm not sure — please advise</option>
                </select>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="c-date">Preferred date</label>
                  <input class="form-input" type="date" id="c-date" name="preferred_date" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="c-guests">Number of guests</label>
                  <select class="form-select" id="c-guests" name="guests">
                    <option value="" disabled selected>Select</option>
                    <option>1 person</option>
                    <option>2 people (5% group discount applies)</option>
                    <option>3 or more (5% group discount applies)</option>
                  </select>
                </div>
              </div>

              <div class="form-field">
                <label class="form-label" for="c-message">Additional notes</label>
                <textarea class="form-textarea" id="c-message" name="message" placeholder="Skin concerns, allergies, preferences or anything else we should know…"></textarea>
              </div>

              <p class="form-note">
                We will respond to confirm availability and provide deposit payment details. A 100% non-refundable deposit is required to secure your appointment.
              </p>

              <button type="submit" class="btn btn-onyx">Send Enquiry</button>
            </form>
          </div>

        </div>
      </div>
    </section>


    <section class="section" id="locations" style="padding-top: 0;">
      <div class="wrap">
        <div class="divider"></div>

        <div class="sec-head fade-up" style="margin-bottom: clamp(2rem, 3.5vw, 3rem);">
          <div>
            <span class="eyebrow">{{ contact.locations_section.eyebrow }}</span>
            <h2 class="t-display t-sm" style="margin-top: 0.35rem;">
              {{ contact.locations_section.heading }}<br><em>{{ contact.locations_section.heading_em }}</em>
            </h2>
          </div>
        </div>

        <div class="locations-grid fade-up d2">
          {% for loc in contact.locations_section.locations %}
          <div class="loc-card">
            <span class="loc-card__city">{{ loc.city }}</span>
            <h3 class="loc-card__name">{{ loc.name }}</h3>
            <p class="loc-card__detail">{{ loc.detail }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>


    <section class="section section--sage">
      <div class="wrap">
        <div class="grid-2 fade-up">

          <div>
            <span class="eyebrow" style="color: rgba(33,26,18,0.5); margin-bottom: 1.25rem; display: block;">Gift Cards</span>
            <h2 class="t-display t-sm" style="margin-bottom: 1rem;">Purchase a<br><em>gift card</em></h2>
            <p class="body-sm" style="opacity: 0.68; margin-bottom: 1.5rem;">
              Gift cards are available from GHS 100, with no upper limit. Redeemable against any service,
              package or product across all five locations. Valid for 90 days from date of purchase.
            </p>
            <a href="/gift-cards.html" class="btn btn-sage">Gift Card Details</a>
          </div>

          <div class="fade-up d2">
            <span class="eyebrow" style="color: rgba(33,26,18,0.5); margin-bottom: 1.25rem; display: block;">Payment methods</span>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <div style="padding: 1rem 0; border-bottom: 1px solid rgba(33,26,18,0.1);">
                <p style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.35rem;">In person</p>
                <p class="body-sm" style="opacity: 0.75;">Cash, bank transfer, Visa, mobile money at any location.</p>
              </div>
              <div style="padding: 1rem 0; border-bottom: 1px solid rgba(33,26,18,0.1);">
                <p style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.35rem;">Mobile money (local)</p>
                <p class="body-sm" style="opacity: 0.75;">
                  MTN: {{ contact.contact.mobile_money.mtn }} &nbsp;·&nbsp; Telecel: {{ contact.contact.mobile_money.telecel }}<br>
                  <span style="opacity: 0.6;">Name: {{ contact.contact.mobile_money.name }}</span>
                </p>
              </div>
              <div style="padding: 1rem 0; border-bottom: 1px solid rgba(33,26,18,0.1);">
                <p style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.35rem;">Bank transfer</p>
                <p class="body-sm" style="opacity: 0.75;">
                  {{ contact.contact.bank_details.account_name }} · {{ contact.contact.bank_details.bank }} · {{ contact.contact.bank_details.branch }}<br>
                  Account: {{ contact.contact.bank_details.account_number }} · Sort: {{ contact.contact.bank_details.sort_code }} · SWIFT: {{ contact.contact.bank_details.swift }}
                </p>
              </div>
              <div style="padding: 1rem 0;">
                <p style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.35rem;">International (mobile money)</p>
                <p class="body-sm" style="opacity: 0.75;">
                  We accept WorldRemit, Sendwave and similar apps. Contact us via WhatsApp for details.
                </p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
</body>
</html>
