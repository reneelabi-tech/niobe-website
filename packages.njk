---
page_id: packages
permalink: /packages.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ packages.meta_title }}</title>
  <meta name="description" content="{{ packages.meta_desc }}" />
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    .deposit-notice {
      position: fixed;
      top: var(--nav-h);
      left: 0; right: 0;
      z-index: 90;
      background: #2F241D;
      color: rgba(247, 243, 236, 0.78);
      text-align: center;
      padding: 0.55rem var(--side);
      font-family: var(--font-sans);
      font-size: 0.5625rem;
      font-weight: 400;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      pointer-events: none;
      user-select: none;
    }
    .pkg-page-hero { padding-top: calc(clamp(4rem, 8vw, 7rem) + 2.125rem); }
    .t-category__title {
      font-family: var(--font-sans);
      font-size: clamp(0.75rem, 1vw, 0.875rem);
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      line-height: 1.4;
    }
    .pkg-row {
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      column-gap: 2rem;
      row-gap: 0;
      padding: 1.75rem 0;
      border-bottom: 1px solid rgba(121, 138, 132, 0.15);
      align-items: baseline;
      transition: padding-left var(--t);
    }
    .pkg-row:hover { padding-left: 0.5rem; }
    .pkg-row__name {
      font-family: var(--font-serif);
      font-size: clamp(1.05rem, 1.6vw, 1.3rem);
      font-weight: 300;
      line-height: 1.25;
      padding-bottom: 0.65rem;
    }
    .pkg-row__desc {
      grid-column: 1 / -1;
      font-size: 0.875rem;
      opacity: 0.55;
      line-height: 1.8;
      max-width: 72ch;
      padding-bottom: 0.9rem;
    }
    .pkg-row__dur {
      font-size: 0.625rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0.38;
      white-space: nowrap;
      padding-bottom: 0.65rem;
    }
    .pkg-row__price {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.05rem;
      white-space: nowrap;
      padding-bottom: 0.65rem;
    }
    .pkg-row__book {
      display: inline-block;
      font-family: var(--font-sans);
      font-size: 0.5625rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--pitch-black);
      border-bottom: 1px solid rgba(33, 26, 18, 0.28);
      padding-bottom: 1px;
      white-space: nowrap;
      transition: opacity var(--tf);
      margin-bottom: 0.65rem;
    }
    .pkg-row__book:hover { opacity: 0.45; }
    .pkg-row__avail {
      grid-column: 1 / -1;
      font-size: 0.6875rem;
      opacity: 0.3;
      letter-spacing: 0.02em;
      padding-bottom: 0.1rem;
    }
    .pkg-sub-label {
      display: block;
      font-family: var(--font-serif);
      font-size: clamp(0.9rem, 1.3vw, 1.1rem);
      font-weight: 300;
      font-style: italic;
      color: var(--pitch-black);
      opacity: 0.38;
      padding-top: clamp(1.75rem, 3.5vw, 2.75rem);
      padding-bottom: 0.6rem;
      border-bottom: 1px solid rgba(121, 138, 132, 0.12);
      margin-bottom: 0;
    }
    @media (max-width: 700px) {
      .pkg-row { grid-template-columns: 1fr auto; column-gap: 1.25rem; }
      .pkg-row__dur { display: none; }
      .pkg-row__price { grid-column: 2; grid-row: 1; }
      .pkg-row__book  { grid-column: 1 / -1; grid-row: 3; margin-top: 0.1rem; margin-bottom: 0.5rem; }
      .pkg-row__desc  { grid-row: 2; }
      .pkg-row__avail { grid-row: 4; }
    }
  </style>
</head>
<body>

  <div class="deposit-notice" role="note" aria-label="Booking information">
    {{ packages.deposit_bar }}
  </div>

  {% include "nav.njk" %}

  <main>

    <div class="page-hero pkg-page-hero">
      <div class="page-hero__inner">
        <span class="eyebrow">{{ packages.hero.eyebrow }}</span>
        <h1 class="t-display t-lg page-hero__title">
          {{ packages.hero.title }}<br><em>{{ packages.hero.title_em }}</em>
        </h1>
        <p class="page-hero__desc">{{ packages.hero.desc }}</p>
      </div>
    </div>


    <section class="section">
      <div class="wrap">
        <div class="intro-note">{{ packages.intro_note }}</div>

        {% for section in packages.sections %}

        <div class="t-category fade-up" id="{{ section.id }}">
          <div class="t-category__header">
            <span class="eyebrow" style="margin-bottom: 0; min-width: 2.5rem;">{{ section.number }}</span>
            <h2 class="t-category__title">{{ section.title }}</h2>
          </div>
          {% if section.intro %}
          <p class="body-sm" style="padding: 1.25rem 0; opacity: 0.6; max-width: 64ch;">{{ section.intro }}</p>
          {% endif %}

          {% if section.subsections %}
            {% for sub in section.subsections %}
            <span class="pkg-sub-label">{{ sub.label }}</span>
            <div class="t-list">
              {% for pkg in sub.packages %}
              <div class="pkg-row fade-up">
                <h3 class="pkg-row__name">{{ pkg.name }}</h3>
                <span class="pkg-row__dur">{{ pkg.duration }}</span>
                <span class="pkg-row__price">{{ pkg.price }}</span>
                <a href="/booking.html" class="pkg-row__book" data-book>Book Now</a>
                <p class="pkg-row__desc">{{ pkg.desc }}</p>
                <span class="pkg-row__avail">Available at: {{ pkg.availability }}</span>
              </div>
              {% endfor %}
            </div>
            {% endfor %}
          {% else %}
            <div class="t-list">
              {% for pkg in section.packages %}
              <div class="pkg-row fade-up">
                <h3 class="pkg-row__name">{{ pkg.name }}</h3>
                <span class="pkg-row__dur">{{ pkg.duration }}</span>
                <span class="pkg-row__price">{{ pkg.price }}</span>
                <a href="/booking.html" class="pkg-row__book" data-book>Book Now</a>
                <p class="pkg-row__desc">{{ pkg.desc }}</p>
                <span class="pkg-row__avail">Available at: {{ pkg.availability }}</span>
              </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {% if not loop.last %}<div class="divider"></div>{% endif %}

        {% endfor %}

      </div>
    </section>


    <section class="section section--sage">
      <div class="wrap">
        <div style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1.75rem;">
          <span class="eyebrow" style="color: rgba(33,26,18,0.5);">{{ packages.cta.eyebrow }}</span>
          <h2 class="t-display t-md fade-up">{{ packages.cta.heading }}<br><em>{{ packages.cta.heading_em }}</em></h2>
          <p class="body-lg fade-up d2" style="opacity: 0.65; max-width: 42ch;">{{ packages.cta.desc }}</p>
          <div class="fade-up d3" style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
            <a href="/booking.html" class="btn btn-onyx" data-book>Book a Package</a>
            <a href="/treatments.html"   class="btn btn-sage">Individual Treatments</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  {% include "footer.njk" %}
  {% include "booking-data.njk" %}
  <script src="/js/main.js"></script>
</body>
</html>
